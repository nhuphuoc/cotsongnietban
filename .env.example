# Supabase — https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Tuỳ chọn: chỉ server (script admin, webhook), không bao giờ expose ra client
# SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth: Authentication → Providers → Google
# URL chuyển hướng trong Supabase (Redirect URLs):
#   http://localhost:3000/auth/callback
#   http://localhost:3001/auth/callback  (nếu dev khác port)
# Thêm URL production khi deploy.
