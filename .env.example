# Supabase — https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase key name differs by dashboard/CLI versions:
# - Prefer `NEXT_PUBLIC_SUPABASE_ANON_KEY` (classic)
# - Or use `NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY` (new)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Tuỳ chọn (server-only): dùng cho API/admin tasks, KHÔNG bao giờ expose ra client
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
# SUPABASE_SECRET_KEY=your-secret-key
#
# Local Supabase:
# 1) npm run supabase:start
# 2) npm run supabase:status  → copy publishable + secret
# 3) set NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# 4) set NEXT_PUBLIC_SUPABASE_ANON_KEY=... (hoặc NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...)
# 5) set SUPABASE_SERVICE_ROLE_KEY=... (hoặc SUPABASE_SECRET_KEY=...) (nếu dùng admin API routes)

# Google OAuth: Authentication → Providers → Google
# URL chuyển hướng trong Supabase (Redirect URLs):
#   http://localhost:3000/auth/callback
#   http://localhost:3001/auth/callback  (nếu dev khác port)
# Thêm URL production khi deploy.
