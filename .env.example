# Supabase — https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase key name differs by dashboard/CLI versions:
# - Prefer `NEXT_PUBLIC_SUPABASE_ANON_KEY` (classic)
# - Or use `NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY` (new)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Tuỳ chọn (server-only): dùng cho API/admin tasks, KHÔNG bao giờ expose ra client
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
# SUPABASE_SECRET_KEY=your-secret-key

# Seed auth users (optional):
# - Local URL: npm run seed:auth
# - Remote URL: npm run seed:auth:remote
# - Optional overrides:
#   SEED_AUTH_PASSWORD=StrongPassword123!
#   SEED_ADMIN_EMAIL=admin@example.com
#   SEED_USER1_EMAIL=user1@example.com
#   SEED_USER2_EMAIL=user2@example.com

# Chỉ tạo/cập nhật 1 admin CSNB (mặc định admin@cotsongnietban.com — xem scripts/seed-admin-csnb.js):
#   node scripts/seed-admin-csnb.js --remote
#   npm run seed:admin:remote
# Tuỳ chọn: ADMIN_EMAIL=... ADMIN_PASSWORD=...

# Google OAuth: Authentication → Providers → Google
# URL chuyển hướng trong Supabase (Redirect URLs):
#   http://localhost:3000/auth/callback
#   http://localhost:3001/auth/callback  (nếu dev khác port)
# Thêm URL production khi deploy.

# ─────────────────────────────────────────────────────────────
# Bunny Stream (video LMS) — server-only, KHÔNG prefix NEXT_PUBLIC_
#
# Dashboard: https://dash.bunny.net → Stream → <Library> → API
# Bật Token Authentication trong Library → Security để có Token Authentication Key.
#
# BUNNY_STREAM_LIBRARY_ID       Số ID thư viện Stream (VD: 123456).
# BUNNY_STREAM_API_KEY          Library API key (dùng cho admin/upload sau này).
# BUNNY_STREAM_TOKEN_KEY        Token Authentication Key (dùng ký playback URL).
# BUNNY_STREAM_TOKEN_TTL_SEC    Tuỳ chọn, mặc định 3600 (1 giờ).
# BUNNY_STREAM_EMBED_HOST       Tuỳ chọn, mặc định iframe.mediadelivery.net.
# BUNNY_STREAM_CDN_HOSTNAME     Tuỳ chọn, VD vz-xxxxxxxx-xxx.b-cdn.net (cho thumbnail).
#
# BUNNY_STREAM_LIBRARY_ID=
# BUNNY_STREAM_API_KEY=
# BUNNY_STREAM_TOKEN_KEY=
# BUNNY_STREAM_TOKEN_TTL_SEC=3600
# BUNNY_STREAM_EMBED_HOST=iframe.mediadelivery.net
# BUNNY_STREAM_CDN_HOSTNAME=
